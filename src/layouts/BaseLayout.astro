---
import '../styles/global.css';
import PaperdocBanner from '../components/PaperdocBanner.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalUrl?: string;
  ogType?: string;
}

const { title, description, image, canonicalUrl, ogType = 'website' } = Astro.props;
const siteTitle = 'LifeFlow - 더 나은 삶을 위한 인사이트';
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const defaultOgImage = 'https://images.pexels.com/photos/1103970/pexels-photo-1103970.jpeg?auto=compress&cs=tinysrgb&w=1200&h=630&dpr=1';
const ogImage = image || defaultOgImage;
const canonical = canonicalUrl || Astro.url.href;
const currentPath = Astro.url.pathname;

// WebSite JSON-LD schema with SearchAction
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'LifeFlow',
  alternateName: 'LifeFlow Blog',
  url: 'https://life-revenue-blog.vercel.app',
  description: '라이프스타일, 금융, 건강, 교육, 여행 전문 블로그 - 더 나은 삶을 위한 실용 정보',
  inLanguage: 'ko-KR',
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://life-revenue-blog.vercel.app/blog/?q={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
};
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="LifeFlow" />
    <meta name="robots" content="index, follow" />
    <meta name="google-site-verification" content="uShjQZTfZFAauTdbCg7ZN0cvDV_ErVoVmdCScJ75TIQ" />
    <meta name="naver-site-verification" content="eded3a7e2f81aa8f856f0d2d303bd871b657fbee" />
    <meta name="theme-color" content="#1e6b5c" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:site_name" content={siteTitle} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Favicon & PWA -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="LifeFlow" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />

    <!-- WebSite Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <!-- Pretendard (본문 산세) + Nanum Myeongjo (신문 세리프) -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Nanum+Myeongjo:wght@400;700;800&display=swap" rel="stylesheet" />

    <!-- LCP: 모바일 상단 배너 우선 로드 (above-the-fold) -->
    <link rel="preload" as="image" href="/pd-promo-m.webp" media="(max-width: 767px)" fetchpriority="high" />

    <!-- Google AdSense -->
    <meta name="google-adsense-account" content="ca-pub-9400779918671270">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9400779918671270" crossorigin="anonymous"></script>

    <!-- Dark Mode Init (FOUC 방지) -->
    <script is:inline>
      (function() {
        // JS 사용 가능 표시 → .reveal 숨김 애니는 JS 있을 때만(미로드 시 콘텐츠 항상 보임)
        document.documentElement.classList.add('js');
        const t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <!-- 페이지별 추가 head 메타(포스트 article:* 등) -->
    <slot name="head" />
  </head>

  <body>
    <!-- Reading Progress -->
    <div class="reading-progress" id="reading-progress"></div>

    <header class="site-header">
      <div class="masthead-strip">
        <div class="masthead-strip-inner">
          <span>더 나은 삶을 위한 인사이트</span>
          <span class="issue">2026 · 매일 업데이트</span>
        </div>
      </div>
      <nav class="nav-container">
        <a href="/" class="site-logo" aria-label="LifeFlow 홈">Life<span class="flow">Flow</span></a>
        <div class="nav-right">
          <div class="nav-links" id="nav-menu">
            <a href="/blog/" class={currentPath === '/blog/' ? 'active' : ''}>Blog</a>
            <a href="/blog/lifestyle/" class={currentPath.includes('/blog/lifestyle') ? 'active' : ''}>라이프스타일</a>
            <a href="/blog/finance/" class={currentPath.includes('/blog/finance') ? 'active' : ''}>금융</a>
            <a href="/blog/health/" class={currentPath.includes('/blog/health') ? 'active' : ''}>건강</a>
            <a href="/blog/education/" class={currentPath.includes('/blog/education') ? 'active' : ''}>교육</a>
            <a href="/blog/travel/" class={currentPath.includes('/blog/travel') ? 'active' : ''}>여행</a>
            <a href="/blog/tags/" class={currentPath.includes('/blog/tags') ? 'active' : ''}>태그</a>
            <a href="https://ai-revenue-blog.vercel.app/" target="_blank" rel="noopener" class="nav-external">TechFlow ↗</a>
          </div>
          <details class="nav-search" id="nav-search">
            <summary class="nav-search-toggle" aria-label="검색">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="5.5" stroke="currentColor" stroke-width="1.7"/><path d="M13.5 13.5 17.5 17.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
            </summary>
            <form class="nav-search-pop" action="/blog/" method="get" role="search">
              <input type="search" name="q" class="nav-search-input" placeholder="글 검색…" aria-label="사이트 검색" autocomplete="off" />
              <button type="submit" class="nav-search-go" aria-label="검색 실행">→</button>
            </form>
          </details>
          <button class="theme-toggle" id="theme-toggle" aria-label="다크 모드 토글">
            <span id="theme-icon">🌙</span>
          </button>
          <button class="nav-toggle" id="nav-toggle" aria-label="메뉴 열기">☰</button>
        </div>
      </nav>
    </header>

    <main class={currentPath === '/' ? 'is-home' : ''}>
      <PaperdocBanner />
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-container">
        <div class="footer-grid">
          <div class="footer-section">
            <h4>카테고리</h4>
            <ul>
              <li><a href="/blog/lifestyle/">라이프스타일</a></li>
              <li><a href="/blog/finance/">금융 & 재테크</a></li>
              <li><a href="/blog/health/">건강 & 운동</a></li>
              <li><a href="/blog/education/">교육 & 학습</a></li>
              <li><a href="/blog/travel/">여행</a></li>
            </ul>
          </div>
          <div class="footer-section">
            <h4>바로가기</h4>
            <ul>
              <li><a href="/blog/">전체 글</a></li>
              <li><a href="/rss.xml">RSS 피드</a></li>
              <li><a href="https://ai-revenue-blog.vercel.app/" target="_blank" rel="noopener">TechFlow 블로그 &rarr;</a></li>
            </ul>
          </div>
          <div class="footer-section">
            <h4>LifeFlow</h4>
            <ul>
              <li><a href="/">홈</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; {new Date().getFullYear()} LifeFlow. All rights reserved.</p>
          <p class="footer-note">
            이 사이트의 일부 링크는 제휴 마케팅 링크이며, 구매 시 소정의 수수료를 받을 수 있습니다.
          </p>
        </div>
      </div>
    </footer>

    <!-- Back to Top -->
    <button class="back-to-top" id="back-to-top" aria-label="맨 위로">↑</button>

    <!-- Service Worker 등록 -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>

    <script>
      // Reading progress + Back to top (rAF 스로틀 단일 passive 핸들러 — 스크롤 중 forced reflow 제거)
      const bar = document.getElementById('reading-progress');
      const btt = document.getElementById('back-to-top');
      let viewH = window.innerHeight;
      let scrollTicking = false;
      function onScrollFrame() {
        scrollTicking = false;
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - viewH;
        const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        if (bar) bar.style.width = pct + '%';
        if (btt) btt.classList.toggle('show', scrollTop > 400);
      }
      window.addEventListener('scroll', () => {
        if (!scrollTicking) { scrollTicking = true; requestAnimationFrame(onScrollFrame); }
      }, { passive: true });
      window.addEventListener('resize', () => { viewH = window.innerHeight; }, { passive: true });
      onScrollFrame();
      btt?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

      // Dark mode toggle
      const toggle = document.getElementById('theme-toggle');
      const icon = document.getElementById('theme-icon');
      function syncIcon() {
        if (icon) icon.textContent = document.documentElement.classList.contains('dark') ? '☀️' : '🌙';
      }
      syncIcon();
      toggle?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        syncIcon();
      });

      // Mobile nav toggle
      const navToggle = document.getElementById('nav-toggle');
      const navMenu = document.getElementById('nav-menu');
      navToggle?.addEventListener('click', () => navMenu?.classList.toggle('open'));

      // 네비 검색: 열면 인풋 포커스, Escape·바깥 클릭 시 닫기
      (function() {
        const ns = document.getElementById('nav-search');
        if (!ns) return;
        const input = ns.querySelector('.nav-search-input');
        ns.addEventListener('toggle', () => { if (ns.open && input) input.focus(); });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') ns.open = false; });
        document.addEventListener('click', (e) => { if (ns.open && !ns.contains(e.target)) ns.open = false; });
      })();
    </script>

    <script>
      // ── Scroll reveal + count-up (생동감) ── 전역 함수로 노출해 포스트에서도 재사용
      (function() {
        const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        function countUp(el) {
          const target = parseFloat(el.getAttribute('data-countup')) || 0;
          const suffix = el.getAttribute('data-suffix') || '';
          const dur = 1100; let start = null;
          function step(ts) {
            if (!start) start = ts;
            const p = Math.min((ts - start) / dur, 1);
            const val = Math.round(target * (1 - Math.pow(1 - p, 3)));
            el.textContent = val + suffix;
            if (p < 1) requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
        }
        let io = null;
        if (!reduce && 'IntersectionObserver' in window) {
          io = new IntersectionObserver((entries) => {
            entries.forEach((en) => {
              if (en.isIntersecting) {
                en.target.classList.add('in');
                if (en.target.hasAttribute('data-countup')) countUp(en.target);
                io.unobserve(en.target);
              }
            });
          }, { threshold: 0.15, rootMargin: '0px 0px -8% 0px' });
        }
        // 전역: 요소(NodeList/배열)를 리빌 관찰 대상으로 등록
        window.__reveal = function(nodes) {
          if (!nodes) return;
          nodes.forEach((el) => {
            if (reduce || !io) { el.classList.add('in'); if (el.hasAttribute('data-countup')) el.textContent = (el.getAttribute('data-countup')) + (el.getAttribute('data-suffix') || ''); return; }
            io.observe(el);
          });
        };
        window.__reveal(document.querySelectorAll('.reveal, [data-countup]'));
      })();
    </script>

    <script>
      // Pageview tracking
      (function() {
        const ANALYTICS_URL = 'https://xyprbsmagtlzebxyxsvj.supabase.co/functions/v1/analytics-ingest';
        const NOTRACK_KEY = '__notrack';
        // 관리자 opt-out: ?admin=1 로 1회 접속하면 이 브라우저는 이후 집계 제외 (?admin=0 로 해제)
        try {
          const q = new URLSearchParams(window.location.search).get('admin');
          if (q === '1') localStorage.setItem(NOTRACK_KEY, '1');
          else if (q === '0') localStorage.removeItem(NOTRACK_KEY);
        } catch (e) {}
        // 1) localhost / 사설망(dev·미리보기)은 집계하지 않음
        const host = window.location.hostname;
        const isLocal = host === 'localhost' || host === '127.0.0.1' || host === '::1' || host === '0.0.0.0'
          || /^192\.168\./.test(host) || /^10\./.test(host) || /^172\.(1[6-9]|2\d|3[01])\./.test(host);
        if (isLocal) return;
        // 2) 관리자 플래그가 있으면 집계하지 않음
        try { if (localStorage.getItem(NOTRACK_KEY) === '1') return; } catch (e) {}
        const slug = window.location.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
        fetch(ANALYTICS_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            event_type: 'pageview',
            source: 'lifeflow',
            metadata: { slug, title: document.title, path: window.location.pathname, referrer: document.referrer || 'direct', user_agent: navigator.userAgent }
          })
        }).catch(() => {});
      })();
    </script>
  </body>
</html>
