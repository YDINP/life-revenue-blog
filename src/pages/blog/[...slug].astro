---
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';

export async function getStaticPaths() {
  const allPosts = Object.fromEntries(Object.entries(await import.meta.glob('../../blog/**/*.md', { eager: true })).filter(([, p]) => !p.frontmatter?.draft));   // draft = 페이지 미생성(숨김)

  return Object.entries(allPosts).map(([path, post]) => {
    const slug = path
      .replace('../../blog/', '')
      .replace('.md', '')
      .split('/')
      .slice(-1)[0];

    return {
      params: { slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content, frontmatter } = post;
---

<BlogPostLayout frontmatter={frontmatter}>
  <Content />
</BlogPostLayout>
