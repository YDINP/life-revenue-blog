---
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = await Astro.glob('../blog/**/*.md');
const sorted = allPosts.sort(
  (a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime()
);

const slugOf = (p) => p.file.replace(/\\/g, '/').split('/').pop().replace('.md', '');
const fmtDate = (d) =>
  new Date(d).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });

const featured = sorted[0];
const picks = sorted.slice(1, 6);
const latest = sorted.slice(6, 15);
const lead = latest[0];
const sideStories = latest.slice(1, 5);
const colStories = latest.slice(5, 9);

const catMeta = {
  finance:   { ko: '금융',        en: 'Finance' },
  health:    { ko: '건강',        en: 'Health' },
  education: { ko: '교육',        en: 'Education' },
  travel:    { ko: '여행',        en: 'Travel' },
  lifestyle: { ko: '라이프스타일', en: 'Lifestyle' },
};
const catKey = (c) => (c || '').toLowerCase();
const meta = (c) => catMeta[catKey(c)] || { ko: c, en: c };

const counts = {};
allPosts.forEach((p) => {
  const k = catKey(p.frontmatter.category);
  counts[k] = (counts[k] || 0) + 1;
});
const topics = ['finance', 'health', 'education', 'travel', 'lifestyle'].map((slug) => ({
  slug,
  ...catMeta[slug],
  count: counts[slug] || 0,
}));

const fCat = meta(featured.frontmatter.category);
---

<BaseLayout
  title="LifeFlow - 더 나은 삶을 위한 인사이트"
  description="라이프스타일, 금융, 건강, 교육, 여행 최신 정보를 제공하는 블로그"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "itemListElement": sorted.slice(0, 10).map((post, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `https://life-revenue-blog.vercel.app/blog/${slugOf(post)}/`
    }))
  })} />

  <!-- ══ Cover story + Curated contents ══ -->
  <section class="cover" aria-label="이번 주 커버스토리">
    <article class="lead">
      <div class="lead-eyebrow">
        <span class="cat-tag" style={`--cat: var(--cat-${catKey(featured.frontmatter.category)})`}>
          {fCat.en} · {fCat.ko}
        </span>
        <span class="kicker">이번 주 커버스토리</span>
      </div>
      <h1><a href={`/blog/${slugOf(featured)}/`}>{featured.frontmatter.title}</a></h1>
      <p class="deck">{featured.frontmatter.description}</p>
      <div class="lead-meta">
        <a href={`/blog/${slugOf(featured)}/`} class="read-cta">전문 읽기 <span class="arw">→</span></a>
        <span class="dotdiv"></span>
        <time class="num">{fmtDate(featured.frontmatter.pubDate)}</time>
      </div>
    </article>

    <aside class="contents" aria-label="이번 주 큐레이션">
      <h2><span>이번 주 큐레이션</span><span class="num">{String(picks.length).padStart(2, '0')}</span></h2>
      {picks.map((post, i) => {
        const m = meta(post.frontmatter.category);
        return (
          <a href={`/blog/${slugOf(post)}/`} class="pick">
            <span class="idx num">{String(i + 1).padStart(2, '0')}</span>
            <span>
              <span class="pick-cat" style={`--cat: var(--cat-${catKey(post.frontmatter.category)})`}>{m.en}</span>
              <span class="pick-title">{post.frontmatter.title}</span>
            </span>
          </a>
        );
      })}
    </aside>
  </section>

  <!-- ══ Latest — 신문 프론트페이지 ══ -->
  <section class="news" aria-label="최신 글">
    <div class="sec-head">
      <div>
        <span class="kicker">Fresh off the press</span>
        <h3>최신 글</h3>
      </div>
      <a href="/blog/" class="read-cta">전체 아카이브 <span class="arw">→</span></a>
    </div>

    <div class="news-top">
      <a class="lead-story" href={`/blog/${slugOf(lead)}/`}>
        {lead.frontmatter.heroImage && (
          <div class="lead-media">
            <img src={lead.frontmatter.heroImage} alt={lead.frontmatter.title} loading="lazy" />
          </div>
        )}
        <div class="lead-text">
          <span class="news-cat" style={`--cat: var(--cat-${catKey(lead.frontmatter.category)})`}>{meta(lead.frontmatter.category).en} · {meta(lead.frontmatter.category).ko}</span>
          <h4 class="lead-hl">{lead.frontmatter.title}</h4>
          <p class="lead-deck">{lead.frontmatter.description}</p>
          <span class="news-meta num">{fmtDate(lead.frontmatter.pubDate)}</span>
        </div>
      </a>

      <div class="news-side">
        {sideStories.map((post) => (
          <a class="side-story" href={`/blog/${slugOf(post)}/`}>
            <span class="news-cat" style={`--cat: var(--cat-${catKey(post.frontmatter.category)})`}>{meta(post.frontmatter.category).en}</span>
            <h5 class="side-hl">{post.frontmatter.title}</h5>
            <span class="news-meta num">{fmtDate(post.frontmatter.pubDate)}</span>
          </a>
        ))}
      </div>
    </div>

    <div class="news-cols">
      {colStories.map((post) => (
        <a class="col-story" href={`/blog/${slugOf(post)}/`}>
          <span class="news-cat" style={`--cat: var(--cat-${catKey(post.frontmatter.category)})`}>{meta(post.frontmatter.category).en}</span>
          <h5 class="col-hl">{post.frontmatter.title}</h5>
          <p class="col-desc">{post.frontmatter.description}</p>
          <span class="news-meta num">{fmtDate(post.frontmatter.pubDate)}</span>
        </a>
      ))}
    </div>
  </section>
  <!-- ══ Browse by topic ══ -->
  <section aria-label="토픽">
    <div class="sec-head">
      <div>
        <span class="kicker">Browse by topic</span>
        <h3>토픽으로 둘러보기</h3>
      </div>
      <span class="sec-label">5 sections · {allPosts.length} articles</span>
    </div>
    <div class="topics">
      {topics.map((t) => (
        <a href={`/blog/${t.slug}/`} class="topic" style={`--cat: var(--cat-${t.slug})`}>
          <div><span class="t-en">{t.en}</span><div class="t-ko">{t.ko}</div></div>
          <div class="t-count"><b class="num">{t.count}</b> 편</div>
        </a>
      ))}
    </div>
  </section>

</BaseLayout>

<style>
  .kicker {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.98rem;
    color: var(--color-text-secondary);
    display: block;
  }

  /* ── Cover ── */
  .cover {
    display: grid;
    grid-template-columns: 1.55fr 1fr;
    border-top: 1.5px solid var(--color-text);
    border-bottom: 1.5px solid var(--color-text);
    margin-bottom: 0.5rem;
  }
  .lead {
    padding: 3rem 2.75rem 3.25rem 0;
    border-right: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    justify-content: center;
    animation: rise 0.6s cubic-bezier(0.2, 0.7, 0.2, 1) both;
  }
  .lead-eyebrow { display: flex; align-items: center; gap: 12px; margin-bottom: 1.25rem; }
  .cat-tag {
    display: inline-flex; align-items: center;
    font-size: 0.72rem; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase;
    color: #fff; background: var(--cat, var(--color-primary));
    padding: 5px 11px; border-radius: 4px; white-space: nowrap;
  }
  .lead h1 {
    font-size: clamp(2.2rem, 4.8vw, 3.9rem);
    font-weight: 850; line-height: 1.06; letter-spacing: -0.035em;
    margin-bottom: 1.25rem;
  }
  .lead h1 a { color: var(--color-text); text-decoration: none; transition: color 0.15s; }
  .lead h1 a:hover { color: var(--color-primary); }
  .lead .deck {
    font-family: var(--font-serif);
    font-size: 1.2rem; line-height: 1.6; color: var(--color-text-secondary);
    max-width: 34ch; margin-bottom: 1.75rem;
  }
  .lead-meta { display: flex; align-items: center; gap: 16px; font-size: 0.85rem; color: var(--color-text-secondary); }
  .read-cta {
    display: inline-flex; align-items: center; gap: 8px;
    font-weight: 700; color: var(--color-text); text-decoration: none;
    border-bottom: 2px solid var(--color-primary); padding-bottom: 3px; transition: gap 0.18s;
  }
  .read-cta:hover { gap: 14px; }
  .read-cta .arw { color: var(--color-primary); }
  .dotdiv { width: 4px; height: 4px; border-radius: 50%; background: var(--color-border-strong); }

  .contents {
    padding: 2.75rem 0 2.75rem 2.5rem;
    animation: rise 0.6s cubic-bezier(0.2, 0.7, 0.2, 1) 0.08s both;
  }
  .contents h2 {
    font-size: 0.76rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--color-text-muted); font-weight: 700;
    padding-bottom: 14px; margin-bottom: 4px; border-bottom: 1px solid var(--color-border);
    display: flex; justify-content: space-between;
  }
  .pick {
    display: grid; grid-template-columns: auto 1fr; gap: 15px; align-items: start;
    padding: 14px 0; border-bottom: 1px solid var(--color-border);
    text-decoration: none; color: inherit; transition: transform 0.18s;
  }
  .pick:hover { transform: translateX(4px); }
  .pick:hover .pick-title { color: var(--color-primary); }
  .pick .idx { font-family: var(--font-serif); font-size: 1.45rem; line-height: 1; color: var(--color-text-muted); padding-top: 2px; }
  .pick-cat { display: block; font-size: 0.64rem; font-weight: 800; letter-spacing: 0.13em; text-transform: uppercase; color: var(--cat, var(--color-primary)); margin-bottom: 5px; }
  .pick-title { display: block; font-size: 1rem; font-weight: 650; line-height: 1.35; letter-spacing: -0.01em; transition: color 0.15s; }

  /* ── Section head ── */
  .sec-head {
    display: flex; align-items: flex-end; justify-content: space-between; gap: 24px;
    padding: 3rem 0 1.4rem;
  }
  .sec-head h3 { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 820; letter-spacing: -0.03em; }
  .sec-head .kicker { margin-bottom: 4px; }
  .sec-label { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-text-muted); font-variant-numeric: tabular-nums; }

  /* ── Topics ── */
  .topics { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; }
  .topic {
    position: relative; border: 1px solid var(--color-border); border-radius: 14px;
    background: var(--color-bg); padding: 20px 18px; overflow: hidden;
    text-decoration: none; color: inherit; min-height: 158px;
    display: flex; flex-direction: column; justify-content: space-between;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  }
  .topic::before { content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: var(--cat); }
  .topic:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: var(--cat); }
  .topic .t-en { font-family: var(--font-serif); font-style: italic; font-size: 0.9rem; color: var(--cat); }
  .topic .t-ko { font-size: 1.28rem; font-weight: 800; letter-spacing: -0.02em; margin-top: 2px; }
  .topic .t-count { font-size: 0.82rem; color: var(--color-text-secondary); display: flex; align-items: center; gap: 6px; }
  .topic .t-count b { color: var(--cat); font-size: 1.45rem; font-weight: 820; }

  /* ── Latest — 신문 프론트페이지 ── */
  .news-top {
    display: grid;
    grid-template-columns: 1.7fr 1fr;
    gap: 0;
    border-top: 2px solid var(--color-text);
    border-bottom: 1px solid var(--color-border);
  }
  .lead-story {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 1.75rem 2rem 1.75rem 0;
    border-right: 1px solid var(--color-border);
  }
  .lead-media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 6px;
    margin-bottom: 1.1rem;
    background: var(--color-bg-secondary);
  }
  .lead-media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .lead-story:hover .lead-media img { transform: scale(1.04); }
  .news-cat {
    display: block;
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cat, var(--color-primary));
    margin-bottom: 0.55rem;
  }
  .lead-hl {
    font-family: var(--font-serif-ko);
    font-size: clamp(1.6rem, 3vw, 2.3rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin-bottom: 0.7rem;
    transition: color 0.15s;
  }
  .lead-story:hover .lead-hl { color: var(--color-primary); }
  .lead-deck {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin-bottom: 0.9rem;
    max-width: 48ch;
  }
  .news-meta { font-size: 0.76rem; color: var(--color-text-muted); font-variant-numeric: tabular-nums; }

  .news-side {
    display: flex;
    flex-direction: column;
    padding-left: 2rem;
  }
  .side-story {
    text-decoration: none;
    color: inherit;
    padding: 1.15rem 0;
    border-bottom: 1px solid var(--color-border);
    transition: transform 0.15s;
  }
  .news-side .side-story:last-child { border-bottom: none; }
  .side-story:hover { transform: translateX(3px); }
  .side-story:hover .side-hl { color: var(--color-primary); }
  .side-hl {
    font-family: var(--font-serif-ko);
    font-size: 1.12rem;
    font-weight: 700;
    line-height: 1.32;
    margin: 0.15rem 0 0.4rem;
    transition: color 0.15s;
  }

  .news-cols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    margin: 0 0 1rem;
  }
  .col-story {
    text-decoration: none;
    color: inherit;
    padding: 1.5rem 1.4rem 1.5rem 0;
    border-right: 1px solid var(--color-border);
    transition: transform 0.15s;
  }
  .news-cols .col-story:last-child { border-right: none; padding-right: 0; }
  .col-story:hover .col-hl { color: var(--color-primary); }
  .col-hl {
    font-family: var(--font-serif-ko);
    font-size: 1.08rem;
    font-weight: 700;
    line-height: 1.32;
    margin: 0.2rem 0 0.5rem;
    transition: color 0.15s;
  }
  .col-desc {
    font-size: 0.86rem;
    line-height: 1.55;
    color: var(--color-text-secondary);
    margin-bottom: 0.6rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @keyframes rise { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .lead, .contents { animation: none; } }

  @media (max-width: 960px) {
    .cover { grid-template-columns: 1fr; }
    .lead { border-right: none; border-bottom: 1px solid var(--color-border); padding: 2.25rem 0 2.25rem; }
    .contents { padding: 2rem 0 0.5rem; }
    .topics { grid-template-columns: repeat(2, 1fr); }
    .news-top { grid-template-columns: 1fr; }
    .lead-story { border-right: none; border-bottom: 1px solid var(--color-border); padding: 1.5rem 0; }
    .news-side { padding-left: 0; padding-top: 0.5rem; }
    .news-cols { grid-template-columns: repeat(2, 1fr); }
    .news-cols .col-story:nth-child(2) { border-right: none; padding-right: 0; }
    .news-cols .col-story:nth-child(1), .news-cols .col-story:nth-child(2) { border-bottom: 1px solid var(--color-border); padding-bottom: 1.4rem; }
    .news-cols .col-story { padding-right: 1.4rem; }
  }
  @media (max-width: 560px) {
    .topics { grid-template-columns: 1fr 1fr; }
    .news-cols { grid-template-columns: 1fr; }
    .news-cols .col-story { border-right: none; border-bottom: 1px solid var(--color-border); padding: 1.2rem 0; }
    .lead h1 { font-size: 2.15rem; }
  }
</style>
