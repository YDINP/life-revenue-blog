---
import BaseLayout from '../../../layouts/BaseLayout.astro';

// 실제 파일시스템의 finance 카테고리 글에서 데이터를 가져온다 — 허구 slug 방지.
const allPosts = Object.entries(import.meta.glob('../../../blog/**/*.md', { eager: true }))
  .filter(([, p]) => !p.frontmatter?.draft)
  .map(([path, post]) => ({
    slug: path.split('/').pop().replace('.md', ''),
    ...post.frontmatter,
  }));

const financePosts = allPosts.filter((p) => p.category === 'finance');

const GROUPS = [
  {
    key: 'basics',
    title: '재테크 입문 & 자산 배분',
    desc: '처음 시작하는 재테크 원칙과 생애주기·목표별 포트폴리오 구성법.',
    slugs: [
      '2026-02-07-2026-financial-planning-guide',
      '2026-02-08-etf-investment-beginners-2026',
      '2026-02-09-asset-allocation-stocks-realestate-crypto',
      '2026-02-16-finance-asset-allocation-by-age-2026-portfolio-strategy',
      '2026-02-24-finance-asset-allocation-guide-2026-risk-based-portfolio',
      '2026-02-25-finance-asset-allocation-checklist-2026-goal-period-based-formula',
      '2026-02-26-finance-2026-personal-finance-books-top-10-must-read-beginners-guide',
      '2026-07-05-finance-2026-wealth-megatrends-5',
      '2026-07-07-finance-etf-investment-beginners-leverage',
      '2026-07-14-finance-financial-literacy-first-salary-beginner-guide',
    ],
  },
  {
    key: 'saving',
    title: '절약 & 소비 습관',
    desc: '월급 관리 앱, 통장 쪼개기, 심리학 기반 절약 습관 만들기.',
    slugs: [
      '2026-02-11-saving-habits-guide-2026',
      '2026-02-14-finance-double-savings-2026-psychological-spending-hack',
      '2026-02-14-finance-saving-habits-guide-2026',
      '2026-03-16-finance-2026-small-spending-saving-psychology-consumption-habit-guide',
      '2026-04-06-finance-2026-salary-management-app-comparison-top-5-guide',
      '2026-07-06-finance-diversified-investment-side-income',
    ],
  },
  {
    key: 'tax',
    title: '절세계좌 & 세금',
    desc: 'ISA·연금저축·IRP부터 주식 양도세, 재산세, 연말정산까지.',
    slugs: [
      '2026-07-08-finance-tax-saving-accounts-isa-pension-irp',
      '2026-07-13-finance-property-tax-july-2026-card-payment-guide',
      '2026-07-14-finance-productive-finance-isa-2026-guide',
      '2026-07-14-finance-stock-tax-saving-guide-2026',
      '2026-07-14-finance-year-end-tax-early-preparation-2026',
    ],
  },
  {
    key: 'deposit',
    title: '예적금 & 금리 전략',
    desc: '파킹통장·정기예금 비교와 금리·인플레이션 국면별 대응법.',
    slugs: [
      '2026-02-15-finance-2026-high-interest-rate-financial-strategy',
      '2026-02-21-finance-2026-inflation-hedge-investment-strategy-real-returns',
      '2026-07-15-finance-savings-deposit-rates-2026-h2',
      '2026-07-12-finance-parking-account-2026-comparison',
      '2026-07-16-finance-deposit-interest-after-tax-real-return-2026',
    ],
  },
  {
    key: 'policy',
    title: '정부지원금 & 청년정책',
    desc: '청년도약·미래적금, 소비쿠폰, 국민연금 개편 등 놓치기 쉬운 정책 혜택.',
    slugs: [
      '2026-07-12-finance-youth-future-savings-2026-guide',
      '2026-07-12-finance-youth-leap-account-2026-guide',
      '2026-07-12-finance-youth-tomorrow-fund-2026-guide',
      '2026-07-15-finance-government-subsidy-2026-h2',
      '2026-07-12-finance-consumption-coupon-2026-expiry-guide',
      '2026-07-14-finance-national-housing-pension-reform-2026',
      '2026-07-20-finance-2027-minimum-wage-10700-real-pay',
    ],
  },
  {
    key: 'sidehustle',
    title: '부업 & 사회초년생 실전',
    desc: '부업 선택·수익화부터 전월세 계약, 상여금 굴리기 같은 생활 밀착 재테크.',
    slugs: [
      '2026-02-19-finance-side-hustle-monetization-guide-2026',
      '2026-02-20-finance-side-hustle-selection-guide-2026-matching-job-types',
      '2026-07-14-finance-jeonse-wolse-lease-checklist-2026',
      '2026-07-14-finance-institutional-selling-individual-investor-strategy-2026',
      '2026-07-16-finance-chuseok-bonus-money-management-2026',
    ],
  },
];

const grouped = GROUPS.map((g) => ({
  ...g,
  posts: g.slugs.map((slug) => financePosts.find((p) => p.slug === slug)).filter(Boolean),
})).filter((g) => g.posts.length > 0);

// 그룹표에 없는 finance 글이 있으면(신규 발행분) 놓치지 않도록 별도 섹션에 자동 편입
const usedSlugs = new Set(GROUPS.flatMap((g) => g.slugs));
const leftover = financePosts.filter((p) => !usedSlugs.has(p.slug));

const orderedForLd = [...grouped.flatMap((g) => g.posts), ...leftover];
const siteUrl = 'https://life-revenue-blog.vercel.app';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      '@id': `${siteUrl}/guide/money/#collectionpage`,
      name: '2026 재테크 입문 가이드',
      description: '자산 배분, 절약 습관, 절세계좌, 예적금, 정부지원금, 부업까지 LifeFlow 재테크 글을 주제별로 묶은 큐레이션 가이드.',
      url: `${siteUrl}/guide/money/`,
      isPartOf: { '@id': `${siteUrl}/#website` },
    },
    {
      '@type': 'ItemList',
      '@id': `${siteUrl}/guide/money/#itemlist`,
      itemListElement: orderedForLd.map((post, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: `${siteUrl}/blog/${post.slug}/`,
        name: post.title,
      })),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: '홈', item: `${siteUrl}/` },
        { '@type': 'ListItem', position: 2, name: '가이드', item: `${siteUrl}/guide/` },
        { '@type': 'ListItem', position: 3, name: '재테크 입문 가이드', item: `${siteUrl}/guide/money/` },
      ],
    },
  ],
};
---

<BaseLayout
  title="2026 재테크 입문 가이드: 자산 배분부터 절세까지"
  description="자산 배분, 절약 습관, 절세계좌, 예적금, 정부지원금, 부업까지 — LifeFlow의 재테크 글을 주제별로 묶은 큐레이션 가이드입니다."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="guide-hub">
    <nav class="breadcrumb" aria-label="breadcrumb">
      <ol>
        <li><a href="/">홈</a></li>
        <li><a href="/guide/">가이드</a></li>
        <li aria-current="page">재테크 입문 가이드</li>
      </ol>
    </nav>

    <header class="hub-header">
      <span class="hub-eyebrow">💰 MONEY GUIDE</span>
      <h1>2026 재테크 입문 가이드: 자산 배분부터 절세까지</h1>
      <p>
        "재테크를 시작하려는데 뭐부터 봐야 할지 모르겠다"는 질문에 답하기 위해 만든 페이지입니다.
        순서는 이렇습니다 — 먼저 <strong>자산 배분의 기본 원칙</strong>을 잡고, 매달 새는 돈을 막는
        <strong>절약 습관</strong>을 붙인 다음, ISA·연금저축 같은 <strong>절세계좌</strong>로 세금을
        줄이고, 파킹통장·예금으로 <strong>단기 자금</strong>을 굴리고, 청년도약계좌 같은
        <strong>정부지원 제도</strong>를 챙기고, 마지막으로 <strong>부업</strong>으로 원금 자체를 늘리는
        흐름입니다.
      </p>
      <p>
        아래 목록은 LifeFlow에 실제로 발행된 재테크 글 {financePosts.length}편을 이 순서에 맞춰
        주제별로 묶은 것입니다. 최신 트렌드 요약이 아니라, 각 주제를 깊게 다룬 개별 글로 바로
        이동할 수 있도록 큐레이션했습니다.
      </p>
    </header>

    {grouped.map((g) => (
      <section class="hub-group" id={g.key}>
        <div class="hub-group-head">
          <h2>{g.title}</h2>
          <p>{g.desc}</p>
        </div>
        <ul class="hub-list">
          {g.posts.map((post) => (
            <li>
              <a href={`/blog/${post.slug}/`}>{post.title}</a>
              <p>{post.description}</p>
            </li>
          ))}
        </ul>
      </section>
    ))}

    {leftover.length > 0 && (
      <section class="hub-group" id="more">
        <div class="hub-group-head">
          <h2>그 외 재테크 글</h2>
          <p>아직 위 분류에 편입되지 않은 최신 글입니다.</p>
        </div>
        <ul class="hub-list">
          {leftover.map((post) => (
            <li>
              <a href={`/blog/${post.slug}/`}>{post.title}</a>
              <p>{post.description}</p>
            </li>
          ))}
        </ul>
      </section>
    )}

    <footer class="hub-footer">
      <a href="/blog/finance/">금융 카테고리 전체 글 보기 →</a>
      <a href="/guide/growth/">자기계발 & 커리어 가이드 →</a>
    </footer>
  </article>
</BaseLayout>

<style>
.guide-hub {
  max-width: 880px;
  margin: 0 auto;
  padding: 2rem 1rem 4rem;
}

.breadcrumb ol {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  list-style: none;
  padding: 0;
  margin: 0 0 1.5rem;
  font-size: 0.85rem;
  color: var(--color-text-muted);
}
.breadcrumb li + li::before {
  content: '/';
  margin-right: 0.4rem;
  color: var(--color-text-muted);
}
.breadcrumb a { color: var(--color-text-secondary); }
.breadcrumb a:hover { color: var(--color-primary); }

.hub-header {
  margin-bottom: 2.5rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid var(--color-border);
}
.hub-eyebrow {
  display: inline-block;
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: var(--cat-finance);
  margin-bottom: 0.6rem;
}
.hub-header h1 {
  font-size: 2rem;
  line-height: 1.3;
  font-weight: 800;
  margin: 0 0 1.2rem;
}
.hub-header p {
  color: var(--color-text-secondary);
  line-height: 1.75;
  margin: 0 0 1rem;
}
.hub-header p:last-child { margin-bottom: 0; }

.hub-group {
  margin-bottom: 2.4rem;
}
.hub-group-head h2 {
  font-size: 1.35rem;
  font-weight: 800;
  margin: 0 0 0.35rem;
}
.hub-group-head p {
  color: var(--color-text-secondary);
  font-size: 0.92rem;
  margin: 0 0 1rem;
}

.hub-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  gap: 0.9rem;
}
.hub-list li {
  border: 1px solid var(--color-border);
  border-radius: 10px;
  padding: 1rem 1.1rem;
  transition: border-color 0.15s ease, background 0.15s ease;
}
.hub-list li:hover {
  border-color: var(--color-primary);
  background: var(--color-bg-secondary);
}
.hub-list a {
  font-weight: 700;
  color: var(--color-text);
  text-decoration: none;
  line-height: 1.45;
}
.hub-list a:hover { color: var(--color-primary); }
.hub-list p {
  margin: 0.35rem 0 0;
  font-size: 0.88rem;
  color: var(--color-text-secondary);
  line-height: 1.55;
}

.hub-footer {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem 1.5rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--color-border);
  font-weight: 700;
}
.hub-footer a { color: var(--color-primary); text-decoration: none; }
.hub-footer a:hover { text-decoration: underline; }
</style>
