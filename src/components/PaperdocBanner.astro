---
// 페이퍼닥 프로모션 (홈 + 모든 포스팅 상단 고정) — 이미지 연출(브리드/샤인/호버)
// ⚠️ 파일명/클래스에 "banner"·"ad" 금지: 광고 차단기가 /banner.* 를 네트워크 차단해
//    이미지가 안 뜨고 링크 alt 텍스트만 노출됨. → pd-promo 네이밍 사용.
---
<a class="pd-promo-link" href="https://paperdoc-web.vercel.app/" target="_blank" rel="noopener sponsored" aria-label="페이퍼닥 - 계약서 AI 분석 플랫폼 바로가기">
  <span class="pd-promo-frame">
    <picture>
      <source media="(max-width: 767px)" srcset="/pd-promo-m.png" width="1916" height="679" />
      <img class="pd-promo-img" src="/pd-promo.png" alt="페이퍼닥 - 계약서 AI 분석 플랫폼" width="2172" height="724" loading="eager" decoding="async" />
    </picture>
    <span class="pd-promo-shine" aria-hidden="true"></span>
    <span class="pd-promo-cta">무료로 검토받기 <span class="pd-promo-arrow" aria-hidden="true">→</span></span>
  </span>
</a>

<style>
  .pd-promo-link {
    display: block;
    width: auto;
    margin: -0.5rem -0.5rem 1.5rem;
  }

  .pd-promo-frame {
    position: relative;
    display: block;
    /* CTA를 배너 너비에 비례시키기 위한 컨테이너 (cqw 기준) */
    container-type: inline-size;
    border-radius: 16px;
    overflow: hidden;
    /* 숨쉬기 글로우 — 시선 유도 */
    animation: pd-promo-breathe 3.2s ease-in-out infinite;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .pd-promo-img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 16px;
  }

  /* 주기적 광택 스윕 */
  .pd-promo-shine {
    position: absolute;
    top: 0;
    left: -60%;
    width: 45%;
    height: 100%;
    pointer-events: none;
    background: linear-gradient(
      100deg,
      transparent 0%,
      rgba(255, 255, 255, 0.05) 35%,
      rgba(255, 255, 255, 0.45) 50%,
      rgba(255, 255, 255, 0.05) 65%,
      transparent 100%
    );
    transform: skewX(-18deg);
    animation: pd-promo-shine 4.5s ease-in-out infinite;
  }

  /* 오버레이 CTA — 하단 URL 우측 빈 영역 */
  .pd-promo-cta {
    position: absolute;
    left: 26%;
    bottom: 9.5%;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    padding: 0.52em 1.05em;
    border-radius: 999px;
    /* 배너 너비에 비례(1.35% of banner width) → 배너 축소 시 동일 비율로 축소 */
    font-size: 1.35cqw;
    font-weight: 800;
    color: #0b1020;
    background: #ffd400;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.35);
    white-space: nowrap;
    animation: pd-promo-cta-pulse 1.8s ease-in-out infinite;
  }
  .pd-promo-arrow {
    display: inline-block;
    animation: pd-promo-arrow 1.1s ease-in-out infinite;
  }

  /* 호버: 살짝 떠오르고 연출 일시정지, CTA 강조 */
  .pd-promo-link:hover .pd-promo-frame {
    transform: translateY(-3px);
    box-shadow: 0 14px 34px -10px rgba(109, 92, 240, 0.5);
    animation-play-state: paused;
  }
  .pd-promo-link:hover .pd-promo-cta {
    background: #ffe14d;
    transform: scale(1.05);
  }

  @keyframes pd-promo-cta-pulse {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.04); }
  }
  @keyframes pd-promo-arrow {
    0%, 100% { transform: translateX(0); }
    50%      { transform: translateX(4px); }
  }

  @keyframes pd-promo-breathe {
    0%, 100% { box-shadow: 0 0 0 rgba(109, 92, 240, 0); }
    50%      { box-shadow: 0 8px 30px -6px rgba(109, 92, 240, 0.4); }
  }

  @keyframes pd-promo-shine {
    0%   { left: -60%; }
    45%  { left: 120%; }
    100% { left: 120%; }
  }

  /* 모바일(≤767px): 전용 배너 이미지(pd-promo-m)는 레이아웃이 달라
     CTA 위치를 하단 URL 오른쪽 빈 공간으로 재배치(+가독 위해 vw 기준 크기) */
  @media (max-width: 767px) {
    .pd-promo-cta {
      left: auto;
      right: 4%;
      bottom: 10%;
      /* 모바일 배너 너비에 비례(3% of banner width) → 배너 크기에 동적 비례 */
      font-size: 3cqw;
      padding: 0.45em 0.95em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pd-promo-frame,
    .pd-promo-shine,
    .pd-promo-cta,
    .pd-promo-arrow {
      animation: none;
    }
  }
</style>
