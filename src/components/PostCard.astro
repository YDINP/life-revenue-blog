---
import { pexelsSrcset } from '../utils/img.js';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  slug: string;
  image?: { url: string; alt: string };
  tags?: string[];
}

const { title, description, pubDate, category, slug, image, tags } = Astro.props;
const dateObj = pubDate instanceof Date ? pubDate : new Date(pubDate);
const formattedDate = dateObj.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
const cardSrcset = image ? pexelsSrcset(image.url, [400, 600, 800]) : undefined;
---

<div class="post-card" data-tags={tags?.join(' ')}>
  <a href={`/blog/${slug}/`} class="post-card-link">
    <div class="post-card-image-wrap">
      {image ? (
        <img
          src={image.url}
          srcset={cardSrcset}
          sizes="(max-width: 900px) 100vw, 400px"
          width="400"
          height="225"
          alt={image.alt}
          class="post-card-image"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="post-card-image-placeholder">
          <span>{category}</span>
        </div>
      )}
    </div>
    <div class="post-card-body">
      <h3>{title}</h3>
      <p>{description}</p>
      <div class="post-card-footer">
        <span class="post-category" data-cat={category.toLowerCase()}>{category}</span>
        <time datetime={dateObj.toISOString()}>{formattedDate}</time>
      </div>
    </div>
  </a>
</div>
