---
/**
 * AdSlot - Google AdSense 광고 슬롯
 *
 * data-ad-slot이 비어있으면 렌더링하지 않음 (auto-ads가 대신 처리).
 * 애드센스 대시보드에서 광고 단위 생성 후 AD_SLOT_IDS에 slot ID 입력하면 즉시 활성화.
 *   - top/bottom: 본문 상·하단 디스플레이
 *   - mid: 본문 중간 인-아티클(fluid)
 *   - anchor: 모바일 하단 고정(스티키)
 */
interface Props {
  position: 'top' | 'bottom' | 'sidebar' | 'mid' | 'anchor';
}

const { position } = Astro.props;

const AD_SLOT_IDS: Record<string, string> = {
  top: '',
  bottom: '',
  sidebar: '',
  mid: '',
  anchor: '',
};

const slotId = AD_SLOT_IDS[position] || '';
const isAnchor = position === 'anchor';
const isMid = position === 'mid';
---

{slotId && isAnchor && (
  <div class="anchor-ad" id="anchor-ad">
    <button class="anchor-ad-close" type="button" aria-label="광고 닫기" onclick="this.parentElement.remove()">×</button>
    <ins class="adsbygoogle"
      style="display:block"
      data-ad-client="ca-pub-9400779918671270"
      data-ad-slot={slotId}
      data-ad-format="auto"
      data-full-width-responsive="true"></ins>
    <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>
)}

{slotId && !isAnchor && (
  <div class="ad-slot" data-ad-position={position}>
    <ins class="adsbygoogle"
      style="display:block"
      data-ad-client="ca-pub-9400779918671270"
      data-ad-slot={slotId}
      data-ad-format={isMid ? 'fluid' : 'auto'}
      data-ad-layout={isMid ? 'in-article' : undefined}
      data-full-width-responsive="true"></ins>
    <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>
)}

<style>
.ad-slot {
  min-height: 100px;
  margin: 2rem 0;
  text-align: center;
}
.anchor-ad {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 60;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.12);
  text-align: center;
  padding: 2px 0;
  min-height: 52px;
}
:global(:root.dark) .anchor-ad {
  background: rgba(18, 19, 26, 0.98);
}
.anchor-ad-close {
  position: absolute;
  top: -22px;
  right: 6px;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  border: none;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 14px;
  line-height: 1;
  cursor: pointer;
}
@media (min-width: 768px) {
  .anchor-ad { display: none; }
}
</style>
